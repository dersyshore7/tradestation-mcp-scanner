{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "functions": {
    "api/manual-scan.ts": {
      "maxDuration": 300
    },
    "api/original-process.ts": {
      "maxDuration": 300
    },
    "api/paper-trader-run.ts": {
      "maxDuration": 300
    },
    "api/paper-trader.ts": {
      "maxDuration": 300
    },
    "api/workflow.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/paper-trader-run?mode=paper&reconcileOrders=true",
      "schedule": "*/5 13-21 * * 1-5"
    },
    {
      "path": "/api/paper-trader-run?mode=live&reconcileOrders=true",
      "schedule": "*/5 13-21 * * 1-5"
    }
  ]
}
